# ---------------------------------------------------------------------------
# Vibe Mapping environment variables.
# Copy to `.env` at the repo root and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# Anthropic Claude (chat + tool use). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# MapTiler basemaps (aerial + streets). https://cloud.maptiler.com/account/keys/
MAPTILER_API_KEY=
# Same key, exposed to the browser/mobile so MapLibre can fetch basemap tiles.
NEXT_PUBLIC_MAPTILER_API_KEY=
# Abstraction hook so the basemap provider can be swapped later.
BASEMAP_PROVIDER=maptiler

# Clerk auth (web + mobile). https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Next.js needs the publishable key exposed to the browser:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# PostgreSQL + PostGIS. Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://vibe:vibe@localhost:5544/vibe

# S3-compatible object storage (MinIO locally). Matches docker-compose.yml defaults.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=vibe
S3_SECRET_KEY=vibe-secret
S3_BUCKET=vibe-uploads

# Service URLs.
# Hono API (shared mobile endpoints).
API_URL=http://localhost:8787
# Base URL the API uses when building public source/share URLs.
PUBLIC_API_URL=http://localhost:8787
# Exposed to the web browser + mobile app.
NEXT_PUBLIC_API_URL=http://localhost:8787

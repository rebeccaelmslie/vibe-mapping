{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "MAPTILER_API_KEY",
    "NEXT_PUBLIC_MAPTILER_API_KEY",
    "LINZ_API_KEY",
    "NEXT_PUBLIC_LINZ_API_KEY",
    "BASEMAP_PROVIDER",
    "CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "DATABASE_URL",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "API_URL",
    "PUBLIC_API_URL",
    "NEXT_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
